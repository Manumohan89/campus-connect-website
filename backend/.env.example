# ═══════════════════════════════════════════════════════
# Campus Connect Backend — Environment Variables
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════

# ── Database (Render PostgreSQL) ─────────────────────
DATABASE_URL=postgresql://user:password@host:5432/campus_connect

# ── Auth ─────────────────────────────────────────────
JWT_SECRET=generate_a_64char_random_string_here

# ── Server ───────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── Frontend URL (CORS) ──────────────────────────────
# Comma-separated for multiple origins:
# campus-connect.online, www.campus-connect.online, your-app.vercel.app
CLIENT_URL=https://campus-connect.online,https://www.campus-connect.online

# ── Optional: Email (for forgot-password) ────────────
# EMAIL_USER=your_gmail@gmail.com
# EMAIL_PASS=your_gmail_app_password

# ── Optional: Cloudinary (for file uploads) ──────────
# CLOUDINARY_URL=cloudinary://key:secret@cloud_name
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_key
# CLOUDINARY_API_SECRET=your_secret

# ── Optional: Payments ───────────────────────────────
# RAZORPAY_KEY_ID=rzp_live_xxx
# RAZORPAY_KEY_SECRET=xxx
# STRIPE_SECRET_KEY=sk_live_xxx

# ── Optional: Push Notifications ─────────────────────
# VAPID_PUBLIC_KEY=xxx
# VAPID_PRIVATE_KEY=xxx
