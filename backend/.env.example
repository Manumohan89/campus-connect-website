# ─── Database ─────────────────────────────────────────────────────────────────
# Cloud (Render): Use DATABASE_URL
DATABASE_URL=postgresql://user:password@host:5432/campusconnect

# Local dev: Use individual vars
DB_USER=postgres
DB_HOST=localhost
DB_NAME=CampusConnect
DB_PASSWORD=yourpassword
DB_PORT=5432

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX_STRING
ACCESS_TOKEN_SECRET=REPLACE_WITH_ANOTHER_RANDOM_STRING
REFRESH_TOKEN_SECRET=REPLACE_WITH_YET_ANOTHER_RANDOM_STRING

# ─── Email (Gmail App Password) ───────────────────────────────────────────────
# Enable 2FA on Gmail, then create App Password at: myaccount.google.com/apppasswords
EMAIL_USER=your.email@gmail.com
EMAIL_PASS=xxxx_xxxx_xxxx_xxxx

# ─── Razorpay (Payments) ──────────────────────────────────────────────────────
# Free account at razorpay.com — enables Premium subscription payments
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=webhook_secret_from_razorpay_dashboard

# Without this, coding platform runs in demo mode (shows structure, no real execution)

# ─── File Storage (Cloudinary) ────────────────────────────────────────────────
# Free 25GB at cloudinary.com — prevents profile photos being lost on Render redeploy
# Without this, uploads are stored locally (lost on each Render deploy)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_URL=

# ─── AI Study Tutor (FREE - Anthropic Claude) ─────────────────────────────────
# Get free API key at: console.anthropic.com (free tier available)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx

# ─── Push Notifications (FREE - VAPID keys) ───────────────────────────────────  
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:your@email.com


# ─── Code Execution (Built-in — FREE, no API key needed) ──────────────────────
# Campus Connect uses its own code execution engine:
# - Python 3 (system python3)
# - JavaScript (system node)  
# - C/C++ (system gcc/g++)
# - Java (system javac/java — install on Render via buildCommand if needed)
# Install Java on Render: add "apt-get install -y default-jre default-jdk" to buildCommand
