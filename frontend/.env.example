# ─── Frontend Environment Variables ──────────────────────────────────────────
# Copy this file to .env and fill in your values
# In production (Render), set these in the Environment tab

# Razorpay PUBLIC key (used for project purchases & custom project payments)
# Get from: razorpay.com → Settings → API Keys
# NOTE: This is the KEY_ID only — never put your KEY_SECRET here
REACT_APP_RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxx

# API base URL (optional — defaults to relative /api which works with proxy)
# Only needed if frontend and backend are on different domains
# REACT_APP_API_URL=https://your-backend.onrender.com
